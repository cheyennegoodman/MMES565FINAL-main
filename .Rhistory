)) +
labs( x = "Island" , y = "Damselfish Mean Abundance") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
##### now with SITE! #####
########## St. Thomas #######################
STT_ABUNDANCE_DAMSELFISH
hist(STT_ABUNDANCE_DAMSELFISH$Location_Abundance_mean)
# not normal
STT_ABUNDANCE_DAMSELFISH$Abundance_log <- log1p(STT_ABUNDANCE_DAMSELFISH$Location_Abundance_mean) # log it
hist(STT_ABUNDANCE_DAMSELFISH$Abundance_log)
# its normal!!!
leveneTest(Abundance_log ~ Location, data = STT_ABUNDANCE_DAMSELFISH)
#Levene's Test for Homogeneity of Variance (center = median)
#       Df F value Pr(>F)
#group  13  1.1654 0.3091
#      166
STT_ADAM_ANOVA <- aov(Abundance_log ~ Location, data = STT_ABUNDANCE_DAMSELFISH)
summary(STT_ADAM_ANOVA) # location is signifigantly different from one another: P-value = 2.11e-14 ***
TukeyHSD(STT_ADAM_ANOVA)
STT_ANOVA<- emmeans(STT_ADAM_ANOVA, ~ Location)
STT_POSTHOC <- cld(STT_ANOVA, Letter = letters)
STT_POSTHOC$.group <- trimws(STT_POSTHOC$.group)
STT_POSTHOC$y_pos <- max(STT_ABUNDANCE_DAMSELFISH$Abundance_log, na.rm = TRUE) * 1.1
BOX_STT_ADAM <- ggplot(STT_ABUNDANCE_DAMSELFISH, aes(x = Location , y = Abundance_log , fill = Location )) +
geom_boxplot() +
geom_text(data = STT_POSTHOC,
aes(x = Location,
y = y_pos,
label = .group),
inherit.aes = FALSE,
size = 6) +
labs( x = "Location" , y = "Damselfish Mean Abundance") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
######################################################################################ST JOHN#################################
STJ_ABUNDANCE_DAMSELFISH
hist(STJ_ABUNDANCE_DAMSELFISH$Location_Abundance_mean) #log it
STJ_ABUNDANCE_DAMSELFISH$Abundance_log <- log1p(STJ_ABUNDANCE_DAMSELFISH$Location_Abundance_mean) # log it
leveneTest(Abundance_log ~ Location, data = STJ_ABUNDANCE_DAMSELFISH)
STJ_ADAM_ANOVA <- aov(Abundance_log ~ Location, data = STJ_ABUNDANCE_DAMSELFISH)
summary(STJ_ADAM_ANOVA)
## oh cool a sig diff - p-value = 1.27e-10 ***
TukeyHSD(STJ_ADAM_ANOVA)
STJ_ANOVA<- emmeans(STJ_ADAM_ANOVA, ~ Location)
STJ_POSTHOC <- cld(STJ_ANOVA, Letter = letters)
STJ_POSTHOC$.group <- trimws(STJ_POSTHOC$.group)
STJ_POSTHOC$y_pos <- max(STJ_ABUNDANCE_DAMSELFISH$Abundance_log, na.rm = TRUE) * 1.1
BOX_STJ_ADAM <- ggplot(STJ_ABUNDANCE_DAMSELFISH, aes(x = Location , y = Abundance_log , fill = Location )) +
geom_boxplot() +
geom_text(data = STJ_POSTHOC,
aes(x = Location,
y = y_pos,
label = .group),
inherit.aes = FALSE,
size = 6) +
labs( x = "Location" , y = "Damselfish Mean Abundance") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
############################################################################################################################################################################ ST. CROIX ################################
hist(STX_ABUNDANCE_DAMSELFISH$Location_Abundance_mean)
# all my data is right skewd lolol at least its all the same
STX_ABUNDANCE_DAMSELFISH$Abundance_log <- log1p(STX_ABUNDANCE_DAMSELFISH$Location_Abundance_mean) # log it
leveneTest(Abundance_log ~ Location, data = STX_ABUNDANCE_DAMSELFISH)
# p-value = 0.9992
STX_ADAM_ANOVA <- aov(Abundance_log ~ Location, data = STX_ABUNDANCE_DAMSELFISH)
summary(STX_ADAM_ANOVA)
# sig diff between location. P-value = <2e-16 ***
TukeyHSD(STX_ADAM_ANOVA)
STX_ANOVA<- emmeans(STX_ADAM_ANOVA, ~ Location)
STX_POSTHOC <- cld(STX_ANOVA, Letter = letters)
STX_POSTHOC$.group <- trimws(STX_POSTHOC$.group)
STX_POSTHOC$y_pos <- max(STX_ABUNDANCE_DAMSELFISH$Abundance_log, na.rm = TRUE) * 1.1
BOX_STX_ADAM <- ggplot(STX_ABUNDANCE_DAMSELFISH, aes(x = Location , y = Abundance_log , fill = Location )) +
geom_boxplot() +
geom_text(data = STX_POSTHOC,
aes(x = Location,
y = y_pos,
label = .group),
inherit.aes = FALSE,
size = 6) +
labs( x = "Location" , y = "Damselfish Mean Abundance") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
